# Calendly scheduling URL (e.g. https://calendly.com/your-team/strategy-call)
NEXT_PUBLIC_CALENDLY_URL=

# Web3Forms access key (https://web3forms.com) — client-side key for form submissions
NEXT_PUBLIC_WEB3FORMS_KEY=

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Public site URL for metadata (e.g. https://ins.fi)
NEXT_PUBLIC_SITE_URL=https://ins.fi
